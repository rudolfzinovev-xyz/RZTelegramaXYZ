# Copy to .env and fill in real values. NEVER commit .env.
# Use strong, randomly-generated secrets for production.

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/rztelegrama"

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Public URL of the app (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"

# Postgres credentials consumed by docker-compose.yml (match DATABASE_URL above).
POSTGRES_USER="user"
POSTGRES_PASSWORD="password"
POSTGRES_DB="rztelegrama"
